{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    "tmpDir": "build/infection",
    "testFramework": "testo",
    // 1 equivalent mutant: OutboxWebhookPublisher::publish() early `return` when
    // `$endpoints === []` — removing it lets foreach iterate over an empty array,
    // producing identical behaviour (no dispatches, no exception).
    "minMsi": 88,
    "mutators": {
        "@default": true
    }
}
